{
  "name": "reacterm",
  "version": "0.1.0",
  "description": "reacterm — compositor-based terminal UI framework for React",
  "type": "module",
  "files": [
    "src",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "reacterm": "./bin/reacterm.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./components": "./src/components/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./widgets": "./src/widgets/index.ts",
    "./templates": "./src/templates/index.ts",
    "./testing": "./src/testing/index.ts",
    "./devtools": "./src/devtools/index.ts",
    "./headless": "./src/hooks/headless/index.ts",
    "./ssh": "./src/ssh/index.ts"
  },
  "author": "Edward Astill",
  "repository": {
    "type": "git",
    "url": "https://github.com/EdwardAstill/reacterm"
  },
  "homepage": "https://github.com/EdwardAstill/reacterm",
  "bugs": {
    "url": "https://github.com/EdwardAstill/reacterm/issues"
  },
  "license": "MIT",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "tsc --noEmit --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest run --config vitest.config.ts src/__tests__/benchmarks.test.ts",
    "test:driver": "vitest run --config vitest.config.ts src/__tests__/testing-driver.test.ts",
    "test:scenarios": "vitest run --config vitest.config.ts src/__tests__/testing-scenario.test.ts",
    "test:pty": "vitest run --config vitest.config.ts src/__tests__/testing-pty.test.ts",
    "test:package": "vitest run --config vitest.package.config.ts",
    "test:api": "vitest run --config vitest.config.ts src/__tests__/api-surface.test.ts",
    "test:all": "bun run test && bun run test:pty && bun run test:api && bun run typecheck",
    "clean": "rm -rf dist",
    "playground": "cd playground && bun install --silent 2>/dev/null && node server.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "ssh2": "^1.17.0"
  },
  "peerDependenciesMeta": {
    "ssh2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4",
    "@types/node": "^20.19.33",
    "@types/react": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "chafa-wasm": "^0.3.3",
    "react": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "commander": "^12",
    "js-yaml": "^4",
    "react-reconciler": "^0.31.0",
    "zod": "^3"
  }
}
