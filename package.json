{
  "name": "reacterm",
  "version": "0.1.0",
  "description": "reacterm — compositor-based terminal UI framework for React",
  "type": "module",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "reacterm": "./bin/reacterm.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js",
      "default": "./dist/components/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js",
      "default": "./dist/hooks/index.js"
    },
    "./widgets": {
      "types": "./dist/widgets/index.d.ts",
      "import": "./dist/widgets/index.js",
      "default": "./dist/widgets/index.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "import": "./dist/templates/index.js",
      "default": "./dist/templates/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.js",
      "default": "./dist/devtools/index.js"
    },
    "./headless": {
      "types": "./dist/hooks/headless/index.d.ts",
      "import": "./dist/hooks/headless/index.js",
      "default": "./dist/hooks/headless/index.js"
    },
    "./ssh": {
      "types": "./dist/ssh/index.d.ts",
      "import": "./dist/ssh/index.js",
      "default": "./dist/ssh/index.js"
    }
  },
  "author": "Edward Astill",
  "repository": {
    "type": "git",
    "url": "https://github.com/EdwardAstill/reacterm"
  },
  "homepage": "https://github.com/EdwardAstill/reacterm",
  "bugs": {
    "url": "https://github.com/EdwardAstill/reacterm/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "test -d node_modules/react && bun run build || (echo '[reacterm prepare] skipping build: node_modules/react not installed; run \"bun install\" first if you need dist/' >&2; exit 0)",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest run --config vitest.config.ts src/__tests__/benchmarks.test.ts",
    "test:driver": "vitest run --config vitest.config.ts src/__tests__/testing-driver.test.ts",
    "test:scenarios": "vitest run --config vitest.config.ts src/__tests__/testing-scenario.test.ts",
    "test:pty": "vitest run --config vitest.config.ts src/__tests__/testing-pty.test.ts",
    "test:all": "bun test && bun run test:pty && bun run build",
    "clean": "rm -rf dist",
    "playground": "cd playground && npm install --silent 2>/dev/null && node server.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "ssh2": "^1.17.0"
  },
  "peerDependenciesMeta": {
    "ssh2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4",
    "@types/node": "^20.19.33",
    "@types/react": "^19.0.0",
    "@types/ssh2": "^1.15.5",
    "chafa-wasm": "^0.3.3",
    "react": "^19.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "commander": "^12",
    "js-yaml": "^4",
    "react-reconciler": "^0.31.0",
    "tsx": "^4.21.0",
    "zod": "^3"
  }
}
